                  "metadataMaxAge": { "type": "integer", "minimum": -1 },
                  "negativeCacheEnabled": { "type": "boolean" },
                  "negativeCacheTtl": { "type": "integer", "minimum": -1 },
                  "httpClientBlocked": { "type": "boolean" },
                  "httpClientAutoBlock": { "type": "boolean" }
                },
                "required": ["name", "remoteUrl"]
              }
            },
            "rawHosted": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
