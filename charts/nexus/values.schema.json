                  "remoteUrl": { "type": "string", "minLength": 1 },
                  "allowAnonymousAccess": { "type": "boolean" },
                  "bearerTokenFromSecret": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string", "minLength": 1 },
                      "key": { "type": "string", "minLength": 1 }
                    },
                    "required": ["name", "key"]
                  },
                  "blobStoreName": { "type": "string" },
                  "online": { "type": "boolean" },
                  "strictContentTypeValidation": { "type": "boolean" },
