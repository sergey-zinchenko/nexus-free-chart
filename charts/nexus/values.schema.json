              "lastName": { "type": "string", "minLength": 1 },
              "emailAddress": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["active", "disabled"] },
              "isAdmin": { "type": "boolean" },
              "password": { "type": "string" },
              "roles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "passwordFromSecret": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "key": { "type": "string", "minLength": 1 }
                }
              },
              "repositoryAccess": {
                "type": "object",
                "properties": {
                  "pypi": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "npm": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "docker": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "huggingface": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "nuget": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "maven": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  },
                  "raw": {
                    "type": "object",
                    "additionalProperties": { "type": "boolean" }
                  }
                }
              }
            },
            "required": ["userId", "firstName", "lastName", "emailAddress"]
          }
        }
      }
